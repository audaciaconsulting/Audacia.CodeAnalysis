  <Target Name="AddGlobalAnalyzerConfigForPackage_AudaciaCodeAnalysisLibraries" BeforeTargets="CoreCompile">
    <ItemGroup>
      <EditorConfigFiles Include="$(MSBuildThisFileDirectory)Audacia.CodeAnalysis.Libraries.globalconfig" Condition="Exists('$(MSBuildThisFileDirectory)Audacia.CodeAnalysis.Libraries.globalconfig')" />
    </ItemGroup>
  </Target>
</Project>
